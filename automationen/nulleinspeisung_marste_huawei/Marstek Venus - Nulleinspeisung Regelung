alias: Marstek Venus - Nulleinspeisung Regelung
description: >
  PI-Regler für Nulleinspeisung. Reagiert auf Shelly/EMMA-Änderungen. Kp=0.6,
  Ki=0.05, Deadband 10W, Hysterese 5W, Clamp 0-2500W. Override wenn EMMA entlädt
  und Marstek noch lädt. Fix: Integral wird immer gespeichert (vor Hysterese).
triggers:
  - entity_id: sensor.hauptsicherung_shellypro3em_a0dd6ca0e0cc_total_active_power
    trigger: state
  - entity_id: sensor.emma_akkuaufladung_entladung
    trigger: state
  - entity_id: switch.marstek_venus_modbus_rs485_steuermodus
    to: "on"
    trigger: state
  - trigger: time_pattern
    minutes: /1
conditions:
  - condition: state
    entity_id: switch.marstek_venus_modbus_rs485_steuermodus
    state: "on"
  - condition: state
    entity_id: input_boolean.marstek_entladen_erlaubt
    state: "on"
actions:
  - choose:
      - conditions:
          - condition: state
            entity_id: select.marstek_venus_modbus_erzwungener_modus
            state: charge
          - condition: template
            value_template: >
              {{ states('sensor.emma_akkuaufladung_entladung') | float(0) < -100
              }}
        sequence:
          - action: input_number.set_value
            target:
              entity_id: input_number.marstek_pi_integral
            data:
              value: 0
          - action: number.set_value
            target:
              entity_id: number.marstek_venus_modbus_entladeleistung_einstellen
            data:
              value: 0
          - action: select.select_option
            target:
              entity_id: select.marstek_venus_modbus_erzwungener_modus
            data:
              option: discharge
      - conditions:
          - condition: state
            entity_id: select.marstek_venus_modbus_erzwungener_modus
            state: charge
          - condition: template
            value_template: >
              {{ states('sensor.emma_akkuaufladung_entladung') | float(0) >=
              -100 }}
        sequence:
          - action: input_number.set_value
            target:
              entity_id: input_number.marstek_pi_integral
            data:
              value: 0
    default:
      - variables:
          shelly: >
            {{
            states('sensor.hauptsicherung_shellypro3em_a0dd6ca0e0cc_total_active_power')
            | float(0) | round(0) | int }}
          emma: >
            {{ states('sensor.emma_akkuaufladung_entladung') | float(0) |
            round(0) | int }}
          current_output: >
            {{ states('number.marstek_venus_modbus_entladeleistung_einstellen')
            | float(0) | round(0) | int }}
          old_integral: |
            {{ states('input_number.marstek_pi_integral') | float(0) }}
          dt: >
            {% set last =
            as_timestamp(states.sensor.hauptsicherung_shellypro3em_a0dd6ca0e0cc_total_active_power.last_changed)
            %} {% set diff = now().timestamp() - last %} {{ [diff, 15] | min |
            round(2) }}
      - variables:
          shelly_eff: |
            {{ (shelly - 15) if shelly > 0 else shelly }}
          error: |
            {{ shelly_eff - emma }}
          new_integral: >
            {% set raw = old_integral + 0.05 * error * dt %} {{ [[raw, -1500] |
            max, 1500] | min | round(2) }}
          new_output: >
            {% set raw = (0.6 * error + new_integral) | round(0) | int %} {{
            [[raw, 0] | max, 2500] | min }}
      - action: input_number.set_value
        target:
          entity_id: input_number.marstek_pi_integral
        data:
          value: "{{ new_integral }}"
      - condition: template
        value_template: |
          {{ error | abs >= 10 }}
      - condition: template
        value_template: |
          {{ (new_output - current_output) | abs > 5 }}
      - choose:
          - conditions:
              - condition: template
                value_template: "{{ new_output <= 0 }}"
            sequence:
              - action: select.select_option
                target:
                  entity_id: select.marstek_venus_modbus_erzwungener_modus
                data:
                  option: standby
              - action: number.set_value
                target:
                  entity_id: number.marstek_venus_modbus_entladeleistung_einstellen
                data:
                  value: 0
        default:
          - action: select.select_option
            target:
              entity_id: select.marstek_venus_modbus_erzwungener_modus
            data:
              option: discharge
          - action: number.set_value
            target:
              entity_id: number.marstek_venus_modbus_entladeleistung_einstellen
            data:
              value: "{{ new_output }}"
mode: single
max_exceeded: silent
